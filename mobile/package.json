{
  "name": "mobile-qa-assignment",
  "version": "1.0.0",
  "description": "Senior QA Engineer take-home assignment: Mobile UI automation (WebdriverIO + Appium, POM) against the built-in Android Settings app",
  "private": true,
  "scripts": {
    "test": "wdio run ./wdio.conf.ts",
    "test:search": "wdio run ./wdio.conf.ts --spec ./test/specs/search-form.spec.ts",
    "test:scroll": "wdio run ./wdio.conf.ts --spec ./test/specs/scroll-and-tap.spec.ts",
    "appium": "appium --allow-insecure=chromedriver_autodownload"
  },
  "devDependencies": {
    "@wdio/appium-service": "^9.4.2",
    "@wdio/cli": "^9.4.2",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.4.2",
    "@wdio/mocha-framework": "^9.4.2",
    "@wdio/spec-reporter": "^9.4.2",
    "@wdio/types": "^9.4.2",
    "appium": "^2.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "wdio-html-nice-reporter": "^8.0.4"
  }
}
